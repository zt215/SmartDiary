<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.back.mapper.DiaryDraftMapper">

    <resultMap id="DiaryDraftResultMap" type="org.example.back.pojo.DiaryDraft">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="diaryDate" column="diary_date"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="findByUserId" parameterType="int" resultMap="DiaryDraftResultMap">
        SELECT * FROM diary_draft WHERE user_id = #{userId} LIMIT 1
    </select>

    <insert id="upsert" parameterType="org.example.back.pojo.DiaryDraft">
        INSERT INTO diary_draft(user_id, title, content, diary_date, update_time)
        VALUES(#{userId}, #{title}, #{content}, #{diaryDate}, #{updateTime})
        ON DUPLICATE KEY UPDATE
            title = VALUES(title),
            content = VALUES(content),
            diary_date = VALUES(diary_date),
            update_time = VALUES(update_time)
    </insert>

    <delete id="deleteByUserId" parameterType="int">
        DELETE FROM diary_draft WHERE user_id = #{userId}
    </delete>

</mapper>
