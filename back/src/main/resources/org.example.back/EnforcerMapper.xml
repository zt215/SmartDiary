<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.back.mapper.EnforcerMapper">

    <resultMap id="EnforcerResultMap" type="org.example.back.pojo.Enforcer">
        <id property="id" column="id"/>
        <result property="uid" column="uid"/>
        <result property="name" column="name"/>
        <result property="password" column="password"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="findById" resultMap="EnforcerResultMap">
        SELECT * FROM enforcer WHERE id = #{id}
    </select>

    <select id="findByPhone" resultMap="EnforcerResultMap">
        SELECT * FROM enforcer WHERE phone = #{phone}
    </select>

    <select id="findByEmail" resultMap="EnforcerResultMap">
        SELECT * FROM enforcer WHERE email = #{email} LIMIT 1
    </select>

    <select id="findByUid" resultMap="EnforcerResultMap">
        SELECT * FROM enforcer WHERE uid = #{uid} LIMIT 1
    </select>

    <update id="updatePassword">
        UPDATE enforcer SET password = #{password}, update_time = NOW() WHERE id = #{id}
    </update>

</mapper>
