<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.back.mapper.CommentMapper">

    <resultMap id="CommentResultMap" type="org.example.back.pojo.Comment">
        <id property="id" column="id"/>
        <result property="circleId" column="circle_id"/>
        <result property="userId" column="user_id"/>
        <result property="content" column="content"/>
        <result property="parentId" column="parent_id"/>
        <result property="likeCount" column="like_count"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="userName" column="name"/>
        <result property="userAvatar" column="avatar"/>
    </resultMap>

    <sql id="CommentSelectColumns">
        c.id,
        c.circle_id,
        c.user_id,
        c.content,
        c.parent_id,
        c.create_time,
        c.update_time,
        (SELECT COUNT(*) FROM comment_like cl WHERE cl.comment_id = c.id) AS like_count
    </sql>

    <insert id="insert" parameterType="org.example.back.pojo.Comment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO comment (circle_id, user_id, content, parent_id, create_time, update_time)
        VALUES (#{circleId}, #{userId}, #{content}, #{parentId}, NOW(), NOW())
    </insert>

    <delete id="deleteById">
        DELETE FROM comment WHERE id = #{id}
    </delete>

    <delete id="deleteByCircleId">
        DELETE FROM comment WHERE circle_id = #{circleId}
    </delete>

    <select id="selectById" resultMap="CommentResultMap">
        SELECT
        <include refid="CommentSelectColumns"/>,
        u.name,
        u.avatar
        FROM comment c
        LEFT JOIN user u ON c.user_id = u.id
        WHERE c.id = #{id}
    </select>

    <select id="selectByCircleId" resultMap="CommentResultMap">
        SELECT
        <include refid="CommentSelectColumns"/>,
        u.name,
        u.avatar
        FROM comment c
        LEFT JOIN user u ON c.user_id = u.id
        WHERE c.circle_id = #{circleId}
        ORDER BY c.create_time ASC
    </select>

    <select id="selectByParentId" resultMap="CommentResultMap">
        SELECT
        <include refid="CommentSelectColumns"/>,
        u.name,
        u.avatar
        FROM comment c
        LEFT JOIN user u ON c.user_id = u.id
        WHERE c.parent_id = #{parentId}
        ORDER BY c.create_time ASC
    </select>

</mapper>
