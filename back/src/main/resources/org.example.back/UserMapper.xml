<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.back.mapper.UserMapper">

    <!-- 结果映射 -->
    <resultMap id="UserResultMap" type="org.example.back.pojo.User">
        <id property="id" column="id"/>
        <result property="uid" column="uid"/>
        <result property="name" column="name"/>
        <result property="password" column="password"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="allowPhoneSearch" column="allow_phone_search"/>
        <result property="allowEmailSearch" column="allow_email_search"/>
        <result property="hidePhone" column="hide_phone"/>
        <result property="hideEmail" column="hide_email"/>
        <result property="birthday" column="birthday"/>
        <result property="address" column="address"/>
        <result property="avatar" column="avatar"/>
        <result property="theme" column="theme"/>
        <result property="accountStatus" column="account_status"/>
    </resultMap>

    <!-- 插入用户 -->
    <insert id="insert" parameterType="org.example.back.pojo.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user(uid, name, password, phone, email, birthday, address, avatar, theme)
        VALUES(#{uid}, #{name}, #{password}, #{phone}, #{email}, #{birthday}, #{address}, #{avatar}, #{theme})
    </insert>
    <!-- 根据用户名查询用户 -->
    <select id="findByName" parameterType="string" resultMap="UserResultMap">
        SELECT * FROM user WHERE name = #{name}
    </select>
    <!-- 根据手机号查询用户 -->
    <select id="findByPhone" parameterType="string" resultMap="UserResultMap">
        SELECT * FROM user WHERE phone = #{phone}
    </select>
    <!-- 根据ID查询用户 -->
    <select id="findById" parameterType="int" resultMap="UserResultMap">
        SELECT * FROM user WHERE id = #{id}
    </select>
    <!-- 更新用户信息 -->
    <update id="update" parameterType="org.example.back.pojo.User">
        UPDATE user
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="password != null">password = #{password},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="email != null">email = #{email},</if>
            <if test="allowPhoneSearch != null">allow_phone_search = #{allowPhoneSearch},</if>
            <if test="allowEmailSearch != null">allow_email_search = #{allowEmailSearch},</if>
            <if test="hidePhone != null">hide_phone = #{hidePhone},</if>
            <if test="hideEmail != null">hide_email = #{hideEmail},</if>
            <if test="birthday != null">birthday = #{birthday},</if>
            <if test="address != null">address = #{address},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="theme != null">theme = #{theme},</if>
            <if test="accountStatus != null">account_status = #{accountStatus},</if>
        </set>
        WHERE id = #{id}
    </update>
    <!-- 删除用户 -->
    <delete id="deleteById" parameterType="int">
        DELETE FROM user WHERE id = #{id}
    </delete>
    <!-- 查询所有用户 -->
    <select id="findAll" resultMap="UserResultMap">
        SELECT * FROM user
    </select>
    <!--查询最大UID-->
    <select id="selectMaxUid" resultType="long">
        SELECT COALESCE(MAX(uid), 9999999) FROM user
    </select>
    <!--根据邮箱查询用户-->
    <select id="findByEmail" parameterType="string" resultMap="UserResultMap">
        SELECT * FROM user WHERE email = #{email} LIMIT 1
    </select>
    <!--根据UID查询用户-->
    <select id="findByUid" parameterType="long" resultMap="UserResultMap">
        SELECT * FROM user WHERE uid = #{uid} LIMIT 1
    </select>

    <resultMap id="AdminUserRowMap" type="org.example.back.pojo.AdminUserRow">
        <id property="id" column="id"/>
        <result property="uid" column="uid"/>
        <result property="name" column="name"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="birthday" column="birthday"/>
        <result property="address" column="address"/>
        <result property="accountStatus" column="account_status"/>
        <result property="banned" column="banned"/>
        <result property="banEndTime" column="ban_end_time"/>
        <result property="banReason" column="ban_reason"/>
        <result property="banCustomReason" column="ban_custom_reason"/>
    </resultMap>

    <select id="selectAllForAdmin" resultMap="AdminUserRowMap">
        SELECT u.id,
               u.uid,
               u.name,
               u.phone,
               u.email,
               u.birthday,
               u.address,
               u.account_status,
               CASE WHEN ub.id IS NOT NULL THEN 1 ELSE 0 END AS banned,
               ub.end_time AS ban_end_time,
               ub.reason AS ban_reason,
               ub.custom_reason AS ban_custom_reason
        FROM user u
        LEFT JOIN user_ban ub ON ub.id = (
            SELECT id FROM user_ban
            WHERE user_id = u.id AND end_time > NOW()
            ORDER BY end_time DESC LIMIT 1
        )
        ORDER BY u.uid ASC
    </select>

    <update id="anonymizeUser">
        UPDATE user
        SET name = '已注销用户',
            password = #{invalidPassword},
            phone = CONCAT('cancelled_', id),
            email = NULL,
            avatar = NULL,
            address = NULL,
            birthday = NULL,
            theme = 'default',
            account_status = 1
        WHERE id = #{id}
    </update>

   <update id="updateByAdmin" parameterType="org.example.back.pojo.User">
        UPDATE user
        SET name = #{name},
            email = #{email},
            birthday = #{birthday},
            address = #{address},
            allow_phone_search = #{allowPhoneSearch},
            allow_email_search = #{allowEmailSearch},
            hide_phone = #{hidePhone},
            hide_email = #{hideEmail}
       WHERE id = #{id}
   </update>

    <select id="searchByKeyword" resultMap="UserResultMap">
        SELECT * FROM user
        WHERE account_status IS NULL OR account_status = 0
        AND (
            phone LIKE CONCAT('%', #{keyword}, '%')
            OR CAST(uid AS CHAR) LIKE CONCAT('%', #{keyword}, '%')
            OR email LIKE CONCAT('%', #{keyword}, '%')
        )
        ORDER BY uid ASC
    </select>

</mapper>
